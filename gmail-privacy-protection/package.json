{
  "name": "gmail-privacy-protection",
  "description": "Gmailのプライバシーを保護するための機能を提供します",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf distributions",
    "npm:deps": "ncu",
    "npm:update-i": "ncu -i",
    "npm:update-all": "ncu -u",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "prettier --write \"**/*.{ts,js,css,html,md,json}\"",
    "tsc": "tsc --noEmit",
    "ci": "npm-run-all prettier eslint:fix tsc clean build"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/chrome": "^0.0.304",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.13.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.15.0",
    "lodash": "^4.17.21",
    "npm-check-updates": "^17.1.14",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.2",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.5.1",
    "type-fest": "^4.34.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  },
  "license": "MIT"
}
